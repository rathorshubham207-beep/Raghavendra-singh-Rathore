<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PRAVAH 2026 | SKIT Jaipur</title>

    <!-- CSS -->
    <link rel="stylesheet" href="style.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
</head>

<body>

    <!-- ================= NAVBAR ================= -->

    <header>

        <nav class="navbar">

            <div class="logo">
                <img src="logo.webp" alt="">
                <h2>PRAVAH</h2>
            </div>

            <ul class="nav-links">

                <li><a href="#home">Home</a></li>

                <li><a href="#about">About</a></li>

                <li><a href="#events">Events</a></li>

                <li><a href="#gallery">Gallery</a></li>

                <li><a href="#register">Register</a></li>

                <li><a href="#contact">Contact</a></li>

            </ul>

            <div class="menu-btn">
                <i class="fa-solid fa-bars"></i>
            </div>

        </nav>

    </header>



    <!-- ================= HERO SECTION ================= -->

    <section id="home" class="hero">

        <div class="overlay"></div>

        <div class="hero-content">

            <h3>SKIT JAIPUR PRESENTS</h3>

            <h1>PRAVAH 2026</h1>

            <p>
                The Biggest Annual Cultural Fest of
                Swami Keshvanand Institute of Technology,
                Management & Gramothan, Jaipur.
            </p>

            <div class="event-info">

                <div class="card">
                    <i class="fa-solid fa-calendar-days"></i>
                    <h3>10 July 2026</h3>
                </div>

                <div class="card">
                    <i class="fa-solid fa-location-dot"></i>
                    <h3>SKIT, Jagatpura</h3>
                </div>

                <div class="card">
                    <i class="fa-solid fa-users"></i>
                    <h3>2000+ Participants</h3>
                </div>

            </div>

            <a href="#register" class="btn">
                Register Now
            </a>

        </div>

    </section>



    <!-- ================= ABOUT ================= -->

    <section id="about" class="about">

        <div class="left">

            <img src="https://images.unsplash.com/photo-1758550445795-278c5867493d?q=80&w=1200&auto=format&fit=crop" alt="Crowd enjoying PRAVAH fest">

        </div>

        <div class="right">

            <h2>About PRAVAH</h2>

            <p>

                PRAVAH is the flagship annual cultural festival of
                Swami Keshvanand Institute of Technology,
                Management & Gramothan (SKIT), Jaipur.

            </p>

            <p>

                Every year thousands of students gather to
                celebrate creativity, innovation,
                music, dance, competitions,
                gaming, fashion, drama,
                photography and unforgettable memories.

            </p>

            <div class="about-cards">

                <div class="mini-card">

                    <i class="fa-solid fa-music"></i>

                    <h3>Music</h3>

                </div>

                <div class="mini-card">

                    <i class="fa-solid fa-gamepad"></i>

                    <h3>Gaming</h3>

                </div>

                <div class="mini-card">

                    <i class="fa-solid fa-camera"></i>

                    <h3>Photography</h3>

                </div>

                <div class="mini-card">

                    <i class="fa-solid fa-masks-theater"></i>

                    <h3>Drama</h3>

                </div>

            </div>

        </div>

    </section>



    <!-- ================= COUNTDOWN ================= -->

    <section class="countdown">

        <h2>Registration Ends In</h2>

        <p>
            Hurry Up! Limited registrations available.
        </p>

        <div class="timer">

            <div class="time-box">

                <h1 id="days">00</h1>

                <span>Days</span>

            </div>

            <div class="time-box">

                <h1 id="hours">00</h1>

                <span>Hours</span>

            </div>

            <div class="time-box">

                <h1 id="minutes">00</h1>

                <span>Minutes</span>

            </div>

            <div class="time-box">

                <h1 id="seconds">00</h1>

                <span>Seconds</span>

            </div>

        </div>

    </section>



    <!-- ================= EVENTS ================= -->

    <section id="events" class="events">

        <h2>Major Attractions</h2>

        <p>
            Explore exciting competitions and cultural performances.
        </p>

        <div class="event-container">

            <div class="event-card">

                <img src="https://images.unsplash.com/photo-1767979350317-1fd33f8db124?q=80&w=1200&auto=format&fit=crop" alt="Dancers performing on stage">

                <h3>Dance Battle</h3>

                <p>
                    Show your moves and compete with the best teams.
                </p>

            </div>

            <div class="event-card">

                <img src="https://images.unsplash.com/photo-1722505531335-ae1727aef1ef?q=80&w=1200&auto=format&fit=crop" alt="Band performing on stage">

                <h3>Battle of Bands</h3>

                <p>
                    Rock the stage with your music and energy.
                </p>

            </div>

            <div class="event-card">

                <img src="https://images.unsplash.com/flagged/photo-1568988041298-26931e97a28e?q=80&w=1200&auto=format&fit=crop" alt="Model walking the ramp at a fashion show">

                <h3>Fashion Show</h3>

                <p>
                    Walk the ramp with style and confidence.
                </p>

            </div>

            <div class="event-card">

                <img src="https://images.unsplash.com/photo-1726442116417-de02f3116eed?q=80&w=1200&auto=format&fit=crop" alt="Esports gaming setup">

                <h3>E-Sports</h3>

                <p>
                    Valorant, BGMI, FIFA, Free Fire and more.
                </p>

            </div>

        </div>

    </section>
    <!-- ================= GALLERY ================= -->

    <section id="gallery" class="gallery">

        <div class="section-title">
            <h2>Gallery</h2>
            <p>Relive the unforgettable moments of PRAVAH.</p>
        </div>

        <div class="gallery-grid">

            <div class="gallery-item reveal">
                <img src="https://images.unsplash.com/photo-1514525253161-7a46d19cd819?q=80&w=800&auto=format&fit=crop" alt="Crowd in front of the fest stage">
            </div>

            <div class="gallery-item reveal">
                <img src="https://images.unsplash.com/photo-1756370256926-e48ca54c5efe?q=80&w=800&auto=format&fit=crop" alt="Dancers in colorful traditional attire">
            </div>

            <div class="gallery-item reveal">
                <img src="https://images.unsplash.com/photo-1756382616831-998e8baf9675?q=80&w=800&auto=format&fit=crop" alt="Dancers posing outdoors in festive costumes">
            </div>

            <div class="gallery-item reveal">
                <img src="https://images.unsplash.com/photo-1767979349910-655bdc4e2f4e?q=80&w=800&auto=format&fit=crop" alt="Dancer in vibrant yellow and red costume">
            </div>

            <div class="gallery-item reveal">
                <img src="https://images.unsplash.com/photo-1774437891694-7f388328d20b?q=80&w=800&auto=format&fit=crop" alt="Women dancing in colorful sarees">
            </div>

            <div class="gallery-item reveal">
                <img src="https://images.unsplash.com/photo-1772536052222-516b9d06d26d?q=80&w=800&auto=format&fit=crop" alt="Performer in traditional attire on stage">
            </div>

            <div class="gallery-item reveal">
                <img src="https://images.unsplash.com/photo-1747324058493-ec26ec45ba86?q=80&w=800&auto=format&fit=crop" alt="Performer dancing in traditional costume">
            </div>

            <div class="gallery-item reveal">
                <img src="https://images.unsplash.com/photo-1747323952942-e8171143f65f?q=80&w=800&auto=format&fit=crop" alt="Performers dancing gracefully in colorful costumes">
            </div>

            <div class="gallery-item reveal">
                <img src="https://images.unsplash.com/photo-1760092189954-5b2f6eb3ca88?q=80&w=800&auto=format&fit=crop" alt="Crowd with hands raised at the concert">
            </div>

        </div>

    </section>



    <!-- ================= REGISTRATION ================= -->

    <section id="register" class="register">

        <div class="section-title">
            <h2>Register for PRAVAH 2026</h2>
            <p>Fill in your details before the registration deadline.</p>
        </div>

        <form id="registrationForm">

            <div class="input-row">

                <div class="input-box">
                    <label>Full Name</label>
                    <input type="text" id="name" required>
                </div>

                <div class="input-box">
                    <label>Roll Number</label>
                    <input type="text" id="roll" required>
                </div>

            </div>


            <div class="input-row">

                <div class="input-box">
                    <label>College Email</label>
                    <input type="email" id="email" required>
                </div>

                <div class="input-box">
                    <label>Phone Number</label>
                    <input type="tel" id="phone" required>
                </div>

            </div>


            <div class="input-row">

                <div class="input-box">
                    <label>Branch</label>

                    <select id="branch">

                        <option>CSE</option>
                        <option>AI</option>
                        <option>AIML</option>
                        <option>IT</option>
                        <option>ECE</option>
                        <option>EE</option>
                        <option>ME</option>
                        <option>CE</option>

                    </select>

                </div>

                <div class="input-box">

                    <label>Batch</label>

                    <select id="batch">

                        <option>2023-27</option>
                        <option>2024-28</option>
                        <option>2025-29</option>
                        <option>2026-30</option>

                    </select>

                </div>

            </div>


            <div class="input-row">

                <div class="input-box">

                    <label>Year</label>

                    <select id="year">

                        <option>1st Year</option>
                        <option>2nd Year</option>
                        <option>3rd Year</option>
                        <option>4th Year</option>

                    </select>

                </div>

                <div class="input-box">

                    <label>Section</label>

                    <input type="text" id="section">

                </div>

            </div>


            <div class="input-row">

                <div class="input-box">

                    <label>Gender</label>

                    <select id="gender">

                        <option>Male</option>
                        <option>Female</option>
                        <option>Other</option>

                    </select>

                </div>

                <div class="input-box">

                    <label>Date of Birth</label>

                    <input type="date" id="dob">

                </div>

            </div>


            <div class="input-row">

                <div class="input-box">

                    <label>Choose Event</label>

                    <select id="event">

                        <option>Dance Battle</option>
                        <option>Battle of Bands</option>
                        <option>Fashion Show</option>
                        <option>Photography</option>
                        <option>Gaming Tournament</option>
                        <option>Drama</option>

                    </select>

                </div>

                <div class="input-box">

                    <label>T-Shirt Size</label>

                    <select id="size">

                        <option>S</option>
                        <option>M</option>
                        <option>L</option>
                        <option>XL</option>

                    </select>

                </div>

            </div>


            <div class="input-box">

                <label>Why do you want to participate?</label>

                <textarea rows="5" id="reason"></textarea>

            </div>


            <div class="checkbox">

                <input type="checkbox" required>

                <label>
                    I certify that all the information provided is correct.
                </label>

            </div>

            <button type="submit" class="register-btn">

                Register Now

            </button>

        </form>

    </section>



    <!-- ================= CONTACT ================= -->

    <section id="contact" class="contact">

        <div class="section-title">

            <h2>Contact Us</h2>

            <p>Reach out for any queries regarding PRAVAH.</p>

        </div>

        <div class="contact-container">

            <div class="contact-card">

                <i class="fa-solid fa-location-dot"></i>

                <h3>Venue</h3>

                <p>SKIT, Jagatpura, Jaipur</p>

            </div>

            <div class="contact-card">

                <i class="fa-solid fa-phone"></i>

                <h3>Phone</h3>

                <p>+91 9876543210</p>

            </div>

            <div class="contact-card">

                <i class="fa-solid fa-envelope"></i>

                <h3>Email</h3>

                <p>pravah@skit.ac.in</p>

            </div>

        </div>

    </section>



    <!-- ================= FOOTER ================= -->

    <footer>

        <h2>PRAVAH 2026</h2>

        <p>
            Swami Keshvanand Institute of Technology,
            Management & Gramothan, Jaipur
        </p>

        <div class="social-icons">

            <a href="#"><i class="fab fa-facebook-f"></i></a>

            <a href="#"><i class="fab fa-instagram"></i></a>

            <a href="#"><i class="fab fa-linkedin-in"></i></a>

            <a href="#"><i class="fab fa-youtube"></i></a>

        </div>

        <p class="copyright">
            © 2026 PRAVAH | All Rights Reserved
        </p>

    </footer>



    <!-- JavaScript -->

    <script src="script.js"></script>

</body>

</html>